{
  "name": "@money-manager/gateway",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@money-manager/shared-kernel": "workspace:*",
    "@money-manager/infrastructure": "workspace:*",
    "axios": "^1.7.0",
    "ioredis": "^5.3.2",
    "opossum": "^8.1.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/opossum": "^8.1.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.ts$": "ts-jest" },
    "collectCoverageFrom": ["**/*.ts", "!**/index.ts"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@money-manager/shared-kernel(.*)$": "<rootDir>/../../packages/shared-kernel/src$1",
      "^@money-manager/infrastructure(.*)$": "<rootDir>/../../packages/infrastructure/src$1"
    },
    "rootDir": ".",
    "roots": ["<rootDir>/src"]
  }
}
