AI_MODEL_NAME=claude-sonnet-4-20250514
AI_MAX_TOKENS=200
AI_TIMEOUT_MS=5000
AI_CONFIDENCE_THRESHOLD=0.7

# Service Configuration
BUDGET_SERVICE_URL=http://localhost:3002
PORT=3003
NODE_ENV=development
