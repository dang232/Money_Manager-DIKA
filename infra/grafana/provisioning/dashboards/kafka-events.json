        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (eventType) (count_over_time({service=~\".+\"} | json | eventType != `` [5m]))",
          "legendFormat": "{{eventType}}",
          "refId": "A"
