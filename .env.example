# ─── Ports ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=3000
TRANSACTION_SERVICE_PORT=3001
BUDGET_SERVICE_PORT=3002
AI_SERVICE_PORT=3003
AUTH_SERVICE_PORT=3004

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

DATABASE_URL_TXN=postgresql://postgres:postgres@postgres-txn:5432/txn_db
DATABASE_URL_BUDGET=postgresql://postgres:postgres@postgres-budget:5432/budget_db
DATABASE_URL_AUTH=postgresql://postgres:postgres@postgres-auth:5432/auth_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ─── Loki ─────────────────────────────────────────────────────────────────────
LOKI_URL=http://loki:3100

# ─── AI ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=change_me_in_production_must_be_at_least_16_chars
JWT_ACCESS_TTL_SECONDS=900
