{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "paths": {
      "@money-manager/shared-kernel": ["packages/shared-kernel/src"],
      "@money-manager/shared-kernel/*": ["packages/shared-kernel/src/*"],
      "@money-manager/infrastructure": ["packages/infrastructure/src"],
      "@money-manager/infrastructure/*": ["packages/infrastructure/src/*"]
    }
  }
}
