{
  "name": "@money-manager/e2e-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testRegex": "\\.(e2e|int)-spec\\.ts$",
    "testTimeout": 30000,
    "transform": {
